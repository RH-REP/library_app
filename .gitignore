# OS/editor noise
.DS_Store
__pycache__/
*.py[cod]

# Local-only files
.env
.env.*
*.local
*.local.*
tmp/
temp/

# ---------------------------------------------------------------------------
# ArtifactForge source repository guard
#
# ArtifactForge itself should stay an engine/template repository.
# User-specific project data created after download/clone must not drift back
# into the ArtifactForge source repository.
#
# Note: .gitignore does not hide changes to files already tracked by Git.
# The tracked files below are source templates/contracts. Downstream project
# repositories may edit them, but those edits must be pushed to the user's own
# project remote, not to ArtifactForge upstream.
# ---------------------------------------------------------------------------

# main_artifact: user project goal/process are generated project data.
main_artifact/*
!main_artifact/README.md
!main_artifact/.goal_template.md
!main_artifact/.development_process_template.md

# sub_artifact: user/worker production units are project data.
sub_artifact/*
!sub_artifact/README.md

# issue_log: keep source-level onboarding notes only.
issue_log/*
!issue_log/README.md
!issue_log/000_development_process/
issue_log/000_development_process/*
!issue_log/000_development_process/README.md
!issue_log/000_development_process/git_remote_usage_note.md

# .core_program: keep contracts and empty lifecycle directories, ignore runtime state.
.core_program/*
!.core_program/README.md
!.core_program/prompts/
!.core_program/prompts/*.md
!.core_program/app/
!.core_program/app/00_initialize_project/
!.core_program/app/00_initialize_project/*.py
!.core_program/app/01_fetch_issue/
!.core_program/app/01_fetch_issue/*.py
!.core_program/app/02_dispatch_queue/
!.core_program/app/02_dispatch_queue/*.py
!.core_program/lib/
!.core_program/lib/artifactforge_dispatch_v1/
!.core_program/lib/artifactforge_dispatch_v1/*.py
!.core_program/lib/artifactforge_dispatch_v1/tests/
!.core_program/lib/artifactforge_dispatch_v1/tests/*.py
!.core_program/fixtures/
!.core_program/fixtures/dry_run/
!.core_program/fixtures/dry_run/*.json
!.core_program/queue/
.core_program/queue/*
!.core_program/queue/.gitkeep
!.core_program/pending/
.core_program/pending/*
!.core_program/pending/.gitkeep
!.core_program/archive/
.core_program/archive/*
!.core_program/archive/.gitkeep

# Runtime state generated by future non-dry-run execution.
.core_program/router_session_id.txt
.core_program/assignment_state.json
.core_program/app/01_fetch_issue/data/
.core_program/app/02_dispatch_queue/data/
.core_program/dry_run_output/
